<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.aiden.ai-news-agent</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
    <string>cd /Users/maegmini/Projects/ai-news-stand &amp;&amp; npm run agent:run &amp;&amp; npm run build</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
      <key>Hour</key>
      <integer>7</integer>
      <key>Minute</key>
      <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/maegmini/Projects/ai-news-stand/logs/agent/agent.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/maegmini/Projects/ai-news-stand/logs/agent/agent.err.log</string>

    <key>RunAtLoad</key>
    <false/>
  </dict>
</plist>
